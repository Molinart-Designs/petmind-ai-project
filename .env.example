# Identidad del proyecto
PROJECT_NAME=asistente-ai-llm
ENVIRONMENT=development

# Proveedor LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=replace_with_your_key
LLM_MODEL=gpt-4o-mini

# API
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=replace_with_a_secure_value

# Vector store (placeholder de semana 2)
VECTOR_STORE_PROVIDER=chroma
VECTOR_STORE_PATH=./data/vector_store

# Logging
LOG_LEVEL=INFO
