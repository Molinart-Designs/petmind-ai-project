# =============================================================================
# Identidad del proyecto y entorno de ejecución
# (Settings: entorno permitido development | test | staging | production)
# =============================================================================
PROJECT_NAME=petmind-ai
ENVIRONMENT=development
APP_VERSION=0.1.0

# =============================================================================
# Servidor HTTP de la API (uvicorn) y autenticación por API key
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_KEY_HEADER_NAME=X-API-Key
API_KEY=replace_with_a_secure_value
# Si es true, una X-API-Key válida permite acceso sin JWT (solo migración temporal).
LEGACY_API_KEY_FALLBACK_ENABLED=false

# =============================================================================
# Auth0 — validación de JWT de acceso y RBAC (claim permissions)
# =============================================================================
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.petmind.example/
AUTH0_ISSUER=https://your-tenant.auth0.com/
AUTH0_ALGORITHMS=RS256

# =============================================================================
# LLM (proveedor y modelo OpenAI para chat + embeddings)
# =============================================================================
LLM_PROVIDER=openai
OPENAI_API_KEY=replace_with_your_key
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Almacén vectorial y conexión a base de datos
# (VECTOR_STORE_PROVIDER: pgvector | chromadb)
# =============================================================================
VECTOR_STORE_PROVIDER=pgvector
DATABASE_URL=postgresql+psycopg://petmind:petmind_dev@localhost:5432/petmind

# =============================================================================
# PostgreSQL — credenciales y host (usadas por docker-compose y por la app)
# En Docker, suele usarse POSTGRES_HOST=postgres y DATABASE_URL apuntando al servicio.
# =============================================================================
POSTGRES_USER=petmind
POSTGRES_PASSWORD=petmind_dev
POSTGRES_DB=petmind
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================================================
# RAG — chunking, recuperación y umbral de similitud
# =============================================================================
CHUNK_SIZE=700
CHUNK_OVERLAP=100
RETRIEVER_TOP_K=4
SIMILARITY_THRESHOLD=0.75

# =============================================================================
# Investigación externa de confianza (capa 2 / fallback tras RAG interno)
# Master switch + política de evidencia provisional en /query
# =============================================================================
ENABLE_TRUSTED_EXTERNAL_RETRIEVAL=false
ALLOW_PROVISIONAL_IN_QUERY=false
EXTERNAL_RESEARCH_TRIGGER_THRESHOLD=0.75
# Hostnames permitidos para L2 (coma). Vacío = registro sin dominios (sin snippets L2).
# Ejemplo: avma.org,wsava.org  |  Alto riesgo: solo asterisco * = cualquier host (Tavily sin include_domains).
TRUSTED_EXTERNAL_ALLOWLIST_DOMAINS=
# Exclusión (prioridad sobre allowlist). Alias aceptado: TRUSTED_EXTERNAL_BLOCKLIST
TRUSTED_EXTERNAL_DENYLIST=
ENABLE_AUTO_SAVE_PROVISIONAL_KNOWLEDGE=false
# Obsoleto: /query siempre devuelve review_draft=null; se mantiene solo por compatibilidad de .env
EXPOSE_REVIEW_DRAFT_IN_QUERY_API=false

# =============================================================================
# Proveedores externos — búsqueda (L2) y extracción de contenido
# TRUSTED_SEARCH_PROVIDER: stub | tavily
# TRUSTED_CONTENT_PROVIDER: stub | firecrawl
# =============================================================================
TRUSTED_SEARCH_PROVIDER=stub
TRUSTED_CONTENT_PROVIDER=stub

# --- Tavily (requerido si TRUSTED_SEARCH_PROVIDER=tavily) ---
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=basic
TAVILY_TOPIC=general
TAVILY_API_BASE_URL=https://api.tavily.com
# Alias equivalente a TAVILY_MAX_RESULTS (ver config.py):
# TRUSTED_EXTERNAL_MAX_RESULTS=5

# --- Firecrawl (requerido si TRUSTED_CONTENT_PROVIDER=firecrawl) ---
FIRECRAWL_API_KEY=
FIRECRAWL_API_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_MAX_URLS_PER_REQUEST=3
FIRECRAWL_TIMEOUT_SECONDS=30
# Alias equivalentes (ver config.py):
# TRUSTED_EXTERNAL_MAX_URLS_TO_SCRAPE=3
# TRUSTED_EXTERNAL_TIMEOUT_SECONDS=30

# =============================================================================
# Logging estructurado
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR | CRITICAL
# =============================================================================
LOG_LEVEL=INFO
LOG_JSON=false
