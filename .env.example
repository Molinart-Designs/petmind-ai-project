# Identidad del proyecto
PROJECT_NAME=petmind-ai
ENVIRONMENT=development
APP_VERSION=0.1.0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_KEY_HEADER_NAME=X-API-Key
API_KEY=replace_with_a_secure_value

# Proveedor LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=replace_with_your_key
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Vector store / database
VECTOR_STORE_PROVIDER=pgvector
DATABASE_URL=postgresql+psycopg://petmind:petmind_dev@localhost:5432/petmind

# PostgreSQL local (útil para docker-compose y scripts)
POSTGRES_USER=petmind
POSTGRES_PASSWORD=petmind_dev
POSTGRES_DB=petmind
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# RAG defaults
CHUNK_SIZE=700
CHUNK_OVERLAP=100
RETRIEVER_TOP_K=4
SIMILARITY_THRESHOLD=0.75

# Logging
LOG_LEVEL=INFO
LOG_JSON=false